# Copy this file to .env and fill in values.
# Eugene loads .env automatically at startup.

# Provider API keys (set the one(s) required by your models in eugene.toml)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_BASE=
MISTRAL_API_KEY=
XAI_API_KEY=

# Optional channel tokens
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# Email (IMAP/SMTP) credentials for the email_manager applet
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# Optional runtime overrides (if you wire these into your config flow)
# EUGENE_API_KEY=
# EUGENE_HOST=127.0.0.1
# EUGENE_PORT=8000
