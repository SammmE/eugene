# Copy this file to .env and fill in your secrets.
# Eugene loads .env automatically at startup (via python-dotenv).
# Only secrets belong here. Everything else (hosts, ports, etc.) goes in applet.toml.

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider API Keys
# Set whichever provider(s) your models in eugene.toml use.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Channel Tokens
# ─────────────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Applet Secrets
# Convention: {APPLET_NAME}_{FIELD_NAME}=value
# Only credentials/secrets go here. Hosts, ports, and other settings
# belong in the applet's applet.toml.
# ─────────────────────────────────────────────────────────────────────────────

# email_manager
EMAIL_MANAGER_IMAP_USER=
EMAIL_MANAGER_IMAP_PASSWORD=
EMAIL_MANAGER_SMTP_USER=
EMAIL_MANAGER_SMTP_PASSWORD=

# calendar
CALENDAR_CALDAV_USER=
CALENDAR_CALDAV_PASSWORD=

# schoology
SCHOOLOGY_CONSUMER_KEY=
SCHOOLOGY_CONSUMER_SECRET=
